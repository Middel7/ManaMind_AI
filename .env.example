# Copier ce fichier en .env et remplir les valeurs
# Le fichier .env ne doit JAMAIS être commité (il est dans .gitignore)

# ── PostgreSQL ──────────────────────────────────────────────────────────────────
# Format : postgresql://utilisateur:motdepasse@hote:port/nom_base
DATABASE_URL=postgresql://manamind:motdepasse@localhost:5432/manamind

# ── Exemples selon la configuration ────────────────────────────────────────────
# Installation locale standard :
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/manamind
#
# Docker Compose (voir docs/DATABASE_SETUP.md) :
#   DATABASE_URL=postgresql://manamind:manamind@localhost:5432/manamind
#
# PostgreSQL sur un port personnalisé :
#   DATABASE_URL=postgresql://user:pass@localhost:5433/manamind
